+static int SV_GetTextBits( const byte *cmd, int cmdlen ) {
+	int n;
+	for ( n = 0; n < cmdlen; n++ ) {
+		if ( cmd[ n ] > 127 ) {
+			return 8;
+		}
+	}
+	return 7;
+}
+
+
+static int SV_GetCmdSize( int Cmd )
+{
+	if ( (unsigned)Cmd <= 0xFF ) {
+		return 1;
+	} else if ( (unsigned)Cmd <= 0xFFFF ) {
+		return 2;
+	} else if ( (unsigned)Cmd <= 0xFFFFFF ) {
+		return 3;
+	} else {
+		return 4;
+	}
+}
